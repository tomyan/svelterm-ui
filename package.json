{
  "name": "@svelterm/ui",
  "version": "0.2.0",
  "description": "UI components for SvelTERM — terminal and browser from the same source",
  "type": "module",
  "license": "MIT",
  "author": "Tom Yandell",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tomyan/svelterm-ui.git"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "svelte": "file:../svelte-fork/packages/svelte",
    "typescript": "^6.0.2"
  },
  "exports": {
    ".": {
      "svelte": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./*.svelte": {
      "svelte": "./src/*.svelte",
      "default": "./src/*.svelte"
    }
  },
  "files": [
    "src",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "tsc && node --test dist/test/*.test.js"
  },
  "peerDependencies": {
    "@svelterm/core": ">=0.11.0",
    "svelte": ">=5"
  },
  "peerDependenciesMeta": {
    "@svelterm/core": {
      "optional": true
    }
  },
  "homepage": "https://svelterm.dev",
  "bugs": {
    "url": "https://github.com/tomyan/svelterm-ui/issues"
  }
}
